# Personal Shopper — copier vers .env et renseigner (ne jamais commiter .env)
# ---------------------------------------------------------------------------

# Mistral AI (obligatoire pour RAG, chat, embeddings, transcription)
MISTRAL_API_KEY=

# Chat, RAG, conseil taille, extraction guide tailles (vision) — ex. mistral-small-latest
MISTRAL_CHAT_MODEL=mistral-small-latest

# Embeddings RAG / recherche / seed (souvent mistral-embed)
MISTRAL_EMBED_MODEL=mistral-embed

# Transcription audio — ex. voxtral-small-latest
MISTRAL_TRANSCRIPTION_MODEL=voxtral-small-latest

# Timeout HTTP global pour les appels API Mistral (secondes)
MISTRAL_HTTP_TIMEOUT_SECONDS=120

# Longueur max de la réponse du conseiller RAG (tokens) — réduire pour des réponses plus courtes
MISTRAL_RAG_MAX_TOKENS=480

# PostgreSQL — soit DATABASE_URL (prioritaire), soit les champs ci-dessous
# Exemple fictif (asyncpg) : postgresql+asyncpg://postgres:changeme@localhost:5432/personal_shopper
DATABASE_URL=

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme
DATABASE_NAME=personal_shopper

# Optionnel : délais base (secondes) — connexion asyncpg / commandes
DATABASE_CONNECT_TIMEOUT_SECONDS=30
DATABASE_COMMAND_TIMEOUT_SECONDS=60

# JWT — en production utiliser : openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Port HTTP exposé sur la machine hôte par Docker Compose (le conteneur écoute toujours sur 8000 en interne)
APP_PORT=8000

# Note : l’application construit DATABASE_URL en interne à partir des variables ci-dessus.
# Exemple équivalent async : postgresql+asyncpg://USER:PASS@HOST:PORT/NAME
